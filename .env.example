# OpenRouter (for GPT-4o and other OpenAI-compatible models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# NVIDIA NIM (for Llama, DeepSeek, Qwen, Mistral, etc. - free tier available)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Default model (used by single-environment agents)
# OpenRouter examples:  openai/gpt-4o  openai/gpt-4o-mini
# NVIDIA NIM examples:  meta/llama-3.3-70b-instruct  deepseek-ai/deepseek-v3-0324
MODEL=openai/gpt-4o
